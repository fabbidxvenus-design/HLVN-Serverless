# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter API Keys (server-only, never expose to client)
OPENROUTER_KEY_1=sk-or-v1-...
OPENROUTER_KEY_2=sk-or-v1-...
OPENROUTER_KEY_3=sk-or-v1-...

# CORS Allowed Origins (comma-separated list)
# Local development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Staging
# CORS_ORIGINS=https://dashboard-staging.vercel.app,https://mobile-staging.vercel.app
# Production - replace placeholders with your actual domains
# CORS_ORIGINS=https://dashboard.yourdomain.com,https://mobile.yourdomain.com