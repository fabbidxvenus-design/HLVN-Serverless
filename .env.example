# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter API Keys (server-only, never expose to client)
OPENROUTER_KEY_1=sk-or-v1-...
OPENROUTER_KEY_2=sk-or-v1-...
OPENROUTER_KEY_3=sk-or-v1-...

# CORS Allowed Origins (comma-separated list, no trailing slash)
# Local development:
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production:
CORS_ORIGINS=https://ocr-gemini-amber.vercel.app
APP_FRONTEND_URL=https://ocr-gemini-amber.vercel.app